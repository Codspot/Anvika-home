# Anvika gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into anvika's ~/.config/containers/systemd/
# {{ANVIKA_HOME}} is replaced at install time.

[Unit]
Description=Anvika gateway (rootless Podman)

[Container]
Image=anvika:local
ContainerName=anvika
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{ANVIKA_HOME}}/.anvika:/home/node/.anvika
EnvironmentFile={{ANVIKA_HOME}}/.anvika/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
